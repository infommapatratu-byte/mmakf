# Admin gate (set on Vercel project → Settings → Environment Variables)
ADMIN_PASSWORD="mmakf2025"

# Long random string for session signing (openssl rand -base64 32)
ADMIN_SESSION_SECRET="change-me-to-a-long-random-string-at-least-32-chars"

# Upstash Redis — auto-injected by Vercel when you add the Upstash integration.
