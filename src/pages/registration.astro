---
import Base from '@/layouts/Base.astro';
import Icon from '@/components/Icon.astro';
import PageHero from '@/components/PageHero.astro';
import { get } from '@/lib/storage';

export const prerender = false;

const fed = await get('federation');
const stateUnits = await get<any[]>('stateUnits');

const memberTypes = [
  { icon: 'medal',     t: 'Athlete',      fee: '₹300 / year',  d: 'Competitive and grading members. Carries your grading record and tournament eligibility across all sanctioned events.' },
  { icon: 'black-belt', t: 'Instructor',  fee: '₹1,000 / year', d: 'Dan-graded teachers certified by the Technical Committee. Required to conduct MMAKF batches and present grading candidates.' },
  { icon: 'karate-gi', t: 'Dojo / Club',  fee: 'Per charter',   d: 'Chartered training centres under a district or state unit. Listed in the federation register with grading and tournament rights.' },
  { icon: 'shield',    t: 'Official',     fee: '₹500 / year',   d: 'Certified judges, referees and coaches empanelled by the Tournament Commission for sanctioned events.' },
];
---

<Base
  title="Registration & ID Verification — MMAKF"
  description="Register with the national federation as an athlete, instructor, dojo or official — and verify any MMAKF member ID against the official register."
>
  <PageHero
    image="https://images.unsplash.com/photo-1555597673-b21d5c935865?auto=format&fit=crop&w=1800&q=70"
    eyebrow="Member Services"
    title={`National <em>registration</em>.`}
    lead="Every athlete, instructor, dojo and official of the federation carries a unique MMAKF ID, recorded in the national register and verifiable by anyone, anywhere."
    pills={['Unique national ID', 'Publicly verifiable']}
  />

  {/* ═══════ MEMBERSHIP TYPES ═══════ */}
  <section>
    <div class="container">
      <div class="section-head fade">
        <div class="eyebrow">Categories</div>
        <h2 class="display-2">Who <em class="r">registers</em>.</h2>
        <div class="rule"></div>
      </div>
      <div class="grid grid-4">
        {memberTypes.map((m) => (
          <div class="card hoverable fade">
            <div class="card-icon"><Icon name={m.icon} size={32} color="var(--gold)" /></div>
            <div class="card-title" style="font-size:1rem">{m.t}</div>
            <div style="font-family:var(--font-display);font-size:.72rem;letter-spacing:.14em;text-transform:uppercase;color:var(--gold);margin-bottom:12px">{m.fee}</div>
            <div class="card-body" style="font-size:.86rem">{m.d}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* ═══════ APPLY ═══════ */}
  <section id="apply" class="bg2">
    <div class="container reg-grid">
      <div class="fade">
        <div class="eyebrow">Apply</div>
        <h2 class="display-2" style="margin-top:14px">Registration <em class="r">application</em>.</h2>
        <div class="rule"></div>
        <p class="lead">
          Submit the application online — you receive an application number instantly.
          The federation office verifies your details with your state or district unit and
          issues your MMAKF ID. Fees are payable on approval via UPI <span class="text-gold">{fed.upi}</span>.
        </p>
        <ul class="reg-steps mt-6">
          <li><strong>01</strong> Submit the application — note your application number.</li>
          <li><strong>02</strong> The office verifies with your unit (within 7 working days).</li>
          <li><strong>03</strong> Pay the registration fee on approval.</li>
          <li><strong>04</strong> Your MMAKF ID is issued and entered in the national register.</li>
        </ul>
      </div>

      <div class="fade">
        <form id="regForm" class="reg-card">
          <div class="reg-card-h">Application Form</div>
          <div class="reg-fields">
            <div class="full">
              <label class="input-label" for="reg-name">Full name / Club name</label>
              <input class="input" id="reg-name" name="name" required maxlength="120" />
            </div>
            <div>
              <label class="input-label" for="reg-phone">Phone (+91)</label>
              <input class="input" id="reg-phone" name="phone" required maxlength="32" />
            </div>
            <div>
              <label class="input-label" for="reg-type">Membership type</label>
              <select class="input" id="reg-type" name="type" required>
                <option value="">Select type</option>
                <option>Athlete</option>
                <option>Instructor</option>
                <option>Dojo / Club</option>
                <option>Official</option>
              </select>
            </div>
            <div>
              <label class="input-label" for="reg-state">State</label>
              <select class="input" id="reg-state" name="state" required>
                <option value="">Select state</option>
                {stateUnits.map((s: any) => <option>{s.state}</option>)}
                <option>Other</option>
              </select>
            </div>
            <div>
              <label class="input-label" for="reg-district">District</label>
              <input class="input" id="reg-district" name="district" maxlength="60" />
            </div>
            <div class="full">
              <label class="input-label" for="reg-grade">Current grade (if any)</label>
              <input class="input" id="reg-grade" name="grade" placeholder="e.g. 5th Kyu, I Dan, or blank" maxlength="60" />
            </div>
          </div>
          <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;margin-top:18px">Submit Application</button>
          <div style="margin-top:12px;color:var(--muted);font-size:.72rem;text-align:center">
            Details are used only for federation registration and unit verification.
          </div>
          <noscript>
            <div style="margin-top:12px;color:var(--off-white);font-size:.8rem;text-align:center">
              JavaScript is required to apply online — call <a href="tel:+919939144318" class="text-gold">{fed.contact.phone}</a>.
            </div>
          </noscript>
        </form>

        <div id="regDone" class="reg-card" style="display:none;text-align:center">
          <div class="reg-card-h" style="color:var(--gold)">Application Received</div>
          <p class="body-txt" style="margin:10px 0 18px">Your application number is</p>
          <div id="regAppNo" class="reg-appno"></div>
          <p class="body-txt" style="margin-top:18px;font-size:.86rem">
            Note it down — quote it in all correspondence. The federation office will
            contact you within 7 working days.
          </p>
        </div>
      </div>
    </div>
  </section>

  {/* ═══════ VERIFY ═══════ */}
  <section id="verify">
    <div class="container" style="max-width:820px">
      <div class="section-head center fade">
        <div class="eyebrow center">Bonafide Check</div>
        <h2 class="display-2">Verify a member <em>ID</em>.</h2>
        <div class="rule gold center"></div>
        <p class="lead" style="margin:0 auto">
          Any MMAKF ID can be checked against the national register — by schools,
          tournament organisers, employers or parents.
        </p>
      </div>

      <form id="verifyForm" class="verify-bar fade">
        <input class="input" name="id" placeholder="e.g. MMAKF-A-2015-00891" aria-label="Member ID" required maxlength="40" style="text-transform:uppercase" />
        <button type="submit" class="btn btn-gold">Verify</button>
      </form>

      <div id="verifyResult" class="fade" style="margin-top:24px"></div>
    </div>
  </section>
</Base>

<style>
  .bg2 { background: var(--bg-2); }
  .reg-grid {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 56px;
    align-items: start;
  }
  @media (max-width: 900px) { .reg-grid { grid-template-columns: 1fr; } }

  .reg-steps { list-style: none; display: flex; flex-direction: column; }
  .reg-steps li {
    display: flex; gap: 16px;
    padding: 13px 4px;
    border-bottom: 1px solid var(--border);
    color: var(--off-white);
    font-size: 0.92rem;
  }
  .reg-steps li:last-child { border-bottom: 0; }
  .reg-steps strong { font-family: var(--font-display); color: var(--gold); font-weight: 600; }

  .reg-card {
    background: var(--card);
    border: 1px solid var(--border-2);
    border-radius: var(--radius);
    padding: 28px;
  }
  .reg-card-h {
    font-family: var(--font-display);
    font-size: 0.7rem;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--gold);
    padding-bottom: 16px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 20px;
  }
  .reg-fields { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  @media (max-width: 520px) { .reg-fields { grid-template-columns: 1fr; } }
  .reg-fields .full { grid-column: 1 / -1; }
  .reg-appno {
    font-family: var(--font-display);
    font-size: 1.6rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: var(--gold-2);
    border: 1px dashed var(--gold-dim);
    padding: 14px;
    border-radius: var(--radius);
  }

  .verify-bar {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 10px;
    max-width: 560px;
    margin: 0 auto;
  }
  @media (max-width: 480px) { .verify-bar { grid-template-columns: 1fr; } }

  :global(.verify-card) {
    background: var(--card);
    border: 1px solid var(--gold-dim);
    border-left: 3px solid var(--gold);
    border-radius: var(--radius);
    padding: 24px 28px;
    max-width: 560px;
    margin: 0 auto;
  }
  :global(.verify-card.notfound) {
    border-color: rgba(176, 24, 24, 0.5);
    border-left-color: var(--red-2);
    text-align: center;
    color: var(--off-white);
  }
  :global(.verify-row) {
    display: flex;
    justify-content: space-between;
    gap: 18px;
    padding: 9px 0;
    border-bottom: 1px solid var(--border);
    font-size: 0.9rem;
  }
  :global(.verify-row:last-child) { border-bottom: 0; }
  :global(.verify-k) {
    font-family: var(--font-display);
    font-size: 0.64rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
    padding-top: 3px;
    flex-shrink: 0;
  }
  :global(.verify-v) { color: var(--white); text-align: right; }
</style>

<script>
  // ── Registration application ──
  const regForm = document.getElementById('regForm') as HTMLFormElement | null;
  regForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = regForm.querySelector('button[type=submit]') as HTMLButtonElement;
    const body = Object.fromEntries(new FormData(regForm).entries());
    btn.disabled = true; btn.textContent = 'Submitting…';
    try {
      const res = await fetch('/api/register', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      const data = await res.json();
      if (!res.ok || !data.ok) throw new Error('bad');
      (document.getElementById('regAppNo') as HTMLElement).textContent = data.appNo;
      regForm.style.display = 'none';
      (document.getElementById('regDone') as HTMLElement).style.display = 'block';
      (window as any).showNotif('Application received. Note your application number.');
    } catch {
      (window as any).showNotif('Could not submit. Please call +91 99391 44318.');
      btn.disabled = false; btn.textContent = 'Submit Application';
    }
  });

  // ── ID verification ──
  const vForm = document.getElementById('verifyForm') as HTMLFormElement | null;
  const vOut = document.getElementById('verifyResult') as HTMLElement | null;
  const esc = (s: any) => String(s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  vForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!vOut) return;
    const btn = vForm.querySelector('button[type=submit]') as HTMLButtonElement;
    const id = String(new FormData(vForm).get('id') || '').trim();
    btn.disabled = true;
    vOut.innerHTML = '<div style="text-align:center;color:var(--muted)">Checking the register…</div>';
    try {
      const res = await fetch('/api/verify?id=' + encodeURIComponent(id));
      const data = await res.json();
      if (data.found) {
        const m = data.member;
        vOut.innerHTML = `<div class="verify-card">
          <div class="verify-row"><span class="verify-k">Member ID</span><span class="verify-v" style="font-family:var(--font-display);font-weight:600;color:var(--gold-2)">${esc(m.id)}</span></div>
          <div class="verify-row"><span class="verify-k">Name</span><span class="verify-v">${esc(m.name)}</span></div>
          <div class="verify-row"><span class="verify-k">Type</span><span class="verify-v">${esc(m.type)}</span></div>
          <div class="verify-row"><span class="verify-k">Grade</span><span class="verify-v">${esc(m.grade)}</span></div>
          <div class="verify-row"><span class="verify-k">State / Unit</span><span class="verify-v">${esc(m.state)} · ${esc(m.unit)}</span></div>
          <div class="verify-row"><span class="verify-k">Status</span><span class="verify-v" style="color:var(--gold-2)">${esc(m.status)} · valid till ${esc(m.validTill)}</span></div>
        </div>`;
      } else {
        vOut.innerHTML = `<div class="verify-card notfound">No member found for <strong>${esc(id.toUpperCase())}</strong>.<br/>
          <span style="font-size:.85rem">Check the ID format (e.g. MMAKF-A-2015-00891) or contact the federation office.</span></div>`;
      }
    } catch {
      vOut.innerHTML = '<div class="verify-card notfound">Could not reach the register. Please try again.</div>';
    } finally {
      btn.disabled = false;
    }
  });
</script>
