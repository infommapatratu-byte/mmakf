---
import Base from '@/layouts/Base.astro';
import ListPanel from '@/components/ListPanel.astro';
import { getAll } from '@/lib/storage';
import { isAuthenticated } from '@/lib/auth';

export const prerender = false;

const authed = isAuthenticated(Astro.request.headers.get('cookie'));
const data = authed ? await getAll() : null;

let leadList: any[] = [];
if (authed) {
  const { get } = await import('@/lib/storage');
  leadList = (await get<any[]>('leads')) || [];
}
---

<Base title="MMAKF Admin" showNav={false} showFooter={false}>
  {!authed ? (
    <section style="min-height:90vh;display:flex;align-items:center;justify-content:center;padding:64px 24px">
      <div style="width:100%;max-width:420px">
        <div style="text-align:center;margin-bottom:36px">
          <div style="font-family:var(--font-display);font-size:1.8rem;font-weight:700;letter-spacing:.06em">MMAKF</div>
          <div style="font-family:var(--font-display);font-size:.7rem;letter-spacing:.22em;text-transform:uppercase;color:var(--gold);margin-top:6px">Administration</div>
        </div>
        <form id="loginForm" class="card" style="padding:32px">
          <h1 class="card-title" style="font-size:1.2rem;margin-bottom:24px">Sign in</h1>
          <label class="input-label">Password</label>
          <input class="input" type="password" name="password" required autofocus />
          <div id="loginErr" style="color:#ff6464;font-size:.85rem;margin-top:12px;display:none">Invalid password</div>
          <button type="submit" class="btn btn-primary" style="width:100%;margin-top:20px;justify-content:center">Unlock</button>
          <p style="margin-top:20px;font-size:.75rem;color:var(--muted);text-align:center">
            Authorised personnel only. All actions are logged.
          </p>
        </form>
      </div>
    </section>

    <script>
      const f = document.getElementById('loginForm');
      const err = document.getElementById('loginErr');
      f.addEventListener('submit', async (e) => {
        e.preventDefault();
        err.style.display = 'none';
        const password = (new FormData(f).get('password')) || '';
        const r = await fetch('/api/auth/login', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ password }),
        });
        if (r.ok) { location.reload(); return; }
        err.style.display = 'block';
        f.querySelector('input[name=password]').select();
      });
    </script>
  ) : (
    <div class="admin-wrap">
      <aside class="admin-side">
        <div class="admin-brand">
          <div class="admin-brand-1">MMAKF</div>
          <div class="admin-brand-2">Admin</div>
        </div>
        <nav class="admin-nav">
          <a href="#dashboard" class="active">Dashboard</a>
          <a href="#federation">Federation Profile</a>
          <a href="#leadership">Leadership</a>
          <a href="#programs">Programs</a>
          <a href="#schedule">Schedule</a>
          <a href="#events">Events</a>
          <a href="#news">News</a>
          <a href="#facilities">Facilities</a>
          <a href="#faqs">FAQs</a>
          <a href="#gallery">Gallery</a>
          <a href="#syllabus">Syllabus</a>
          <a href="#branches">Branches</a>
          <a href="#products">Shop Products</a>
          <a href="#achievements">Achievements</a>
          <a href="#testimonials">Testimonials</a>
          <a href="#leads">Enrolment Leads</a>
        </nav>
        <div style="padding:16px;border-top:1px solid var(--border)">
          <button class="btn btn-ghost" style="width:100%;justify-content:center" id="logoutBtn">Logout</button>
          <a href="/" target="_blank" class="btn-link" style="display:block;text-align:center;margin-top:10px">View Site →</a>
        </div>
      </aside>

      <main class="admin-main">
        <div class="admin-toast" id="toast">Saved</div>

        <section id="dashboard" class="admin-panel">
          <h2 class="admin-h">Dashboard</h2>
          <div class="grid grid-4" style="margin-top:24px">
            <div class="card"><div class="card-eyebrow">Programs</div><div class="admin-stat">{data!.programs.length}</div></div>
            <div class="card"><div class="card-eyebrow">Events</div><div class="admin-stat">{data!.events.length}</div></div>
            <div class="card"><div class="card-eyebrow">News</div><div class="admin-stat">{data!.news.length}</div></div>
            <div class="card"><div class="card-eyebrow">Products</div><div class="admin-stat">{data!.products.length}</div></div>
          </div>
          <div class="card" style="margin-top:24px">
            <div class="card-eyebrow">Quick links</div>
            <div style="display:flex;flex-wrap:wrap;gap:10px;margin-top:14px">
              <button class="btn btn-ghost" onclick="scrollTo({top:document.getElementById('news')!.offsetTop-20,behavior:'smooth'})">Post News</button>
              <button class="btn btn-ghost" onclick="scrollTo({top:document.getElementById('events')!.offsetTop-20,behavior:'smooth'})">Add Event</button>
              <button class="btn btn-ghost" onclick="scrollTo({top:document.getElementById('schedule')!.offsetTop-20,behavior:'smooth'})">Edit Schedule</button>
              <button class="btn btn-ghost" onclick="scrollTo({top:document.getElementById('leads')!.offsetTop-20,behavior:'smooth'})">View Leads</button>
            </div>
          </div>
        </section>

        <section id="federation" class="admin-panel">
          <h2 class="admin-h">Federation Profile</h2>
          <p class="admin-sub">Identity shown across the public site.</p>
          <form data-key="federation" class="admin-form" data-mode="object" style="margin-top:20px">
            <div class="grid grid-2">
              <div><label class="input-label">Full name</label><input class="input" name="name" value={data!.federation.name} /></div>
              <div><label class="input-label">Short name</label><input class="input" name="shortName" value={data!.federation.shortName} /></div>
              <div style="grid-column:1/-1"><label class="input-label">Tagline</label><input class="input" name="tagline" value={data!.federation.tagline} /></div>
              <div><label class="input-label">Founded</label><input class="input" name="founded" value={data!.federation.founded} /></div>
              <div><label class="input-label">Style</label><input class="input" name="style" value={data!.federation.style} /></div>
              <div><label class="input-label">Lineage</label><input class="input" name="lineage" value={data!.federation.lineage} /></div>
              <div><label class="input-label">Headquarters</label><input class="input" name="headquarters" value={data!.federation.headquarters} /></div>
              <div><label class="input-label">Affiliation</label><input class="input" name="affiliation" value={data!.federation.affiliation} /></div>
              <div><label class="input-label">UPI ID</label><input class="input" name="upi" value={data!.federation.upi} /></div>
              <div><label class="input-label">Email</label><input class="input" name="contact.email" value={data!.federation.contact.email} /></div>
              <div><label class="input-label">Phone</label><input class="input" name="contact.phone" value={data!.federation.contact.phone} /></div>
              <div style="grid-column:1/-1"><label class="input-label">Address</label><input class="input" name="contact.address" value={data!.federation.contact.address} /></div>
              <div style="grid-column:1/-1"><label class="input-label">Office hours</label><input class="input" name="contact.hours" value={data!.federation.contact.hours} /></div>
            </div>
            <button type="submit" class="btn btn-primary" style="margin-top:18px">Save Profile</button>
          </form>
        </section>

        <ListPanel id="leadership" title="Leadership"     subtitle="Office bearers and active senseis." apiKey="leadership"
          rows={data!.leadership} fields={[
            {n:'name',l:'Name'},{n:'role',l:'Role'},{n:'rank',l:'Rank'},{n:'note',l:'Note',full:true}
          ]} />

        <ListPanel id="programs" title="Programs" subtitle="Training programs shown on the public site." apiKey="programs"
          rows={data!.programs} fields={[
            {n:'ico',l:'Icon'},{n:'name',l:'Name'},{n:'lvl',l:'Level'},{n:'mode',l:'Mode'},{n:'fee',l:'Fee (₹/mo)',type:'number'},{n:'desc',l:'Description',full:true}
          ]} />

        <ListPanel id="schedule" title="Schedule" subtitle="Weekly class schedule." apiKey="schedule"
          rows={data!.schedule} fields={[
            {n:'day',l:'Day'},{n:'t',l:'Time'},{n:'d',l:'Discipline'},{n:'lvl',l:'Level'},{n:'ins',l:'Instructor'},{n:'mode',l:'Mode (dojo/online)'}
          ]} />

        <ListPanel id="events" title="Events & Tournaments" subtitle="Upcoming events shown on the public site." apiKey="events"
          rows={data!.events} fields={[
            {n:'day',l:'Day'},{n:'mo',l:'Month'},{n:'year',l:'Year'},{n:'type',l:'Type'},{n:'fee',l:'Fee'},{n:'t',l:'Title',full:true},{n:'loc',l:'Location',full:true}
          ]} />

        <ListPanel id="news" title="News & Announcements" subtitle="Posts shown in the News section." apiKey="news"
          rows={data!.news} fields={[
            {n:'title',l:'Title',full:true},{n:'date',l:'Date'},{n:'type',l:'Type'},{n:'body',l:'Body',full:true,textarea:true}
          ]} />

        <ListPanel id="facilities" title="Dojo Facilities" subtitle="Facilities shown on the /facilities page." apiKey="facilities"
          rows={data!.facilities} fields={[
            {n:'icon',l:'Icon (e.g. mat, water, cctv)'},{n:'name',l:'Name'},{n:'tag',l:'Tag'},{n:'desc',l:'Description',full:true,textarea:true}
          ]} />

        <ListPanel id="faqs" title="FAQs" subtitle="Questions shown on the /faq page." apiKey="faqs"
          rows={data!.faqs} fields={[
            {n:'q',l:'Question',full:true},{n:'a',l:'Answer',full:true,textarea:true}
          ]} />

        <ListPanel id="gallery" title="Gallery" subtitle="Items shown on the /gallery page." apiKey="gallery"
          rows={data!.gallery} fields={[
            {n:'icon',l:'Icon'},{n:'title',l:'Title'},{n:'cat',l:'Category'},{n:'desc',l:'Caption',full:true}
          ]} />

        <ListPanel id="syllabus" title="Grading Syllabus" subtitle="Kata syllabus rows on the /belt-system page." apiKey="syllabus"
          rows={data!.syllabus} fields={[
            {n:'grade',l:'Grading (e.g. 10th → 9th Kyu)'},{n:'belt',l:'Belt'},{n:'kumite',l:'Kumite'},{n:'kihon',l:'Kihon',full:true},{n:'kata',l:'Kata',full:true}
          ]} />

        <ListPanel id="branches" title="Branch Network" subtitle="Centres listed on the /affiliation page." apiKey="branches"
          rows={data!.branches} fields={[
            {n:'name',l:'Centre name',full:true},{n:'city',l:'City'},{n:'district',l:'District'},{n:'incharge',l:'In-charge'},{n:'status',l:'Status'}
          ]} />

        <ListPanel id="products" title="Shop Products" subtitle="Equipment & merchandise." apiKey="products"
          rows={data!.products} fields={[
            {n:'e',l:'Emoji'},{n:'cat',l:'Category'},{n:'badge',l:'Badge'},{n:'p',l:'Price (₹)',type:'number'},{n:'m',l:'MRP (₹)',type:'number'},{n:'n',l:'Name',full:true}
          ]} />

        <ListPanel id="achievements" title="Achievements" subtitle="Institutional achievements." apiKey="achievements"
          rows={data!.achievements} fields={[
            {n:'ico',l:'Icon'},{n:'title',l:'Title'},{n:'badge',l:'Badge'},{n:'body',l:'Body',full:true,textarea:true}
          ]} />

        <ListPanel id="testimonials" title="Testimonials" subtitle="Words of warriors." apiKey="testimonials"
          rows={data!.testimonials} fields={[
            {n:'name',l:'Name'},{n:'role',l:'Role'},{n:'txt',l:'Testimonial',full:true,textarea:true}
          ]} />

        <section id="leads" class="admin-panel">
          <h2 class="admin-h">Enrolment Leads</h2>
          <p class="admin-sub">Captured from the public site enrol form. Most recent first.</p>
          <div class="card" style="margin-top:20px;padding:0;overflow:hidden">
            {leadList.length === 0 ? (
              <div style="padding:32px;text-align:center;color:var(--muted)">No leads yet.</div>
            ) : (
              <table class="schedule-tbl" style="min-width:0">
                <thead><tr><th>When</th><th>Name</th><th>Phone</th><th>Program</th></tr></thead>
                <tbody>
                  {leadList.slice(0, 100).map((l: any) => (
                    <tr>
                      <td class="text-muted" style="font-size:.78rem">{new Date(l.ts).toLocaleString('en-IN')}</td>
                      <td>{l.name}</td>
                      <td class="text-gold">{l.phone}</td>
                      <td>{l.program}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            )}
          </div>
        </section>
      </main>
    </div>
  )}
</Base>

{authed && (
  <style is:global>
    body { background: var(--bg); }
    .admin-wrap { display: grid; grid-template-columns: 260px 1fr; min-height: 100vh; }
    @media (max-width: 800px) { .admin-wrap { grid-template-columns: 1fr; } }

    .admin-side {
      background: var(--bg-2);
      border-right: 1px solid var(--border);
      padding: 24px 0;
      display: flex; flex-direction: column;
      position: sticky; top: 0; align-self: start;
      height: 100vh;
    }
    @media (max-width: 800px) { .admin-side { position: static; height: auto; } }
    .admin-brand { padding: 0 24px 24px; border-bottom: 1px solid var(--border); }
    .admin-brand-1 { font-family: var(--font-display); font-size: 1.4rem; font-weight: 700; letter-spacing: 0.06em; }
    .admin-brand-2 { font-family: var(--font-display); font-size: 0.66rem; letter-spacing: 0.22em; text-transform: uppercase; color: var(--gold); margin-top: 4px; }
    .admin-nav { flex: 1; overflow-y: auto; padding: 16px 12px; display: flex; flex-direction: column; gap: 2px; }
    .admin-nav a {
      padding: 10px 14px;
      font-family: var(--font-display);
      font-size: 0.78rem;
      letter-spacing: 0.08em;
      color: var(--off-white);
      border-radius: var(--radius);
      transition: all 0.18s;
    }
    .admin-nav a:hover, .admin-nav a.active { background: var(--card); color: var(--gold); }

    .admin-main { padding: 32px 36px 64px; max-width: 1100px; }
    @media (max-width: 600px) { .admin-main { padding: 24px 18px 48px; } }

    .admin-panel { padding: 36px 0; border-bottom: 1px solid var(--border); scroll-margin-top: 20px; }
    .admin-panel:first-of-type { padding-top: 0; }
    .admin-h {
      font-family: var(--font-display);
      font-size: 1.5rem;
      font-weight: 600;
      letter-spacing: 0.02em;
    }
    .admin-sub { color: var(--muted); font-size: 0.88rem; margin-top: 6px; }
    .admin-stat {
      font-family: var(--font-display);
      font-size: 2.4rem;
      font-weight: 600;
      color: var(--gold);
      margin-top: 6px;
      line-height: 1;
    }

    .admin-toast {
      position: fixed; bottom: 24px; right: 24px;
      background: var(--card);
      border: 1px solid var(--gold);
      color: var(--gold);
      padding: 12px 20px;
      border-radius: var(--radius);
      font-family: var(--font-display);
      font-size: 0.78rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      opacity: 0;
      transform: translateY(20px);
      transition: all 0.24s;
      pointer-events: none;
      z-index: 999;
    }
    .admin-toast.show { opacity: 1; transform: none; }

    .lp-list { display: flex; flex-direction: column; gap: 10px; margin-top: 18px; }
    .lp-item {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 14px 18px;
      display: grid; grid-template-columns: 1fr auto; gap: 14px;
      align-items: center;
    }
    .lp-item-body { font-size: 0.9rem; }
    .lp-item-name { font-family: var(--font-display); font-weight: 600; font-size: 0.98rem; color: var(--white); }
    .lp-item-meta { color: var(--muted); font-size: 0.78rem; margin-top: 4px; }
    .lp-item-actions { display: flex; gap: 8px; }
    .lp-btn-del {
      background: transparent;
      border: 1px solid var(--border-2);
      color: var(--off-white);
      padding: 6px 12px;
      font-family: var(--font-display);
      font-size: 0.7rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      border-radius: var(--radius);
      cursor: pointer;
    }
    .lp-btn-del:hover { border-color: var(--red); color: var(--red-2); }

    .lp-form { background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); padding: 20px; margin-top: 18px; }
    .lp-form .lp-form-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; }
    @media (max-width: 800px) { .lp-form .lp-form-grid { grid-template-columns: 1fr 1fr; } }
    @media (max-width: 500px) { .lp-form .lp-form-grid { grid-template-columns: 1fr; } }
    .lp-form .full { grid-column: 1 / -1; }
  </style>

  <script is:inline define:vars={{ data: data }}>
    // Toast
    function toast(msg) {
      const t = document.getElementById('toast');
      if (!t) return;
      t.textContent = msg || 'Saved';
      t.classList.add('show');
      clearTimeout(window._tt);
      window._tt = setTimeout(() => t.classList.remove('show'), 1800);
    }

    // Logout
    document.getElementById('logoutBtn')?.addEventListener('click', async () => {
      await fetch('/api/auth/logout', { method: 'POST' });
      location.reload();
    });

    // Object form (federation)
    function setNested(obj, path, val) {
      const ks = path.split('.');
      let o = obj;
      for (let i = 0; i < ks.length - 1; i++) {
        if (!o[ks[i]] || typeof o[ks[i]] !== 'object') o[ks[i]] = {};
        o = o[ks[i]];
      }
      o[ks[ks.length - 1]] = val;
    }
    document.querySelectorAll('form.admin-form[data-mode="object"]').forEach((form) => {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const key = form.dataset.key;
        const fd = new FormData(form);
        const out = JSON.parse(JSON.stringify(data[key]));
        fd.forEach((v, k) => setNested(out, k, v));
        const r = await fetch('/api/data/' + key, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(out),
        });
        if (r.ok) { data[key] = out; toast('Profile saved'); }
        else toast('Save failed');
      });
    });

    // List panels
    document.querySelectorAll('section[data-key][data-fields]').forEach((panel) => {
      const key = panel.dataset.key;
      const fields = JSON.parse(panel.dataset.fields);
      const listEl = panel.querySelector('.lp-list');
      const addForm = panel.querySelector('.lp-form');

      function render() {
        const rows = data[key] || [];
        listEl.innerHTML = rows.map((r, i) => {
          const main = fields[0]?.n;
          const secondary = fields.filter((f, idx) => idx > 0 && r[f.n] !== undefined && r[f.n] !== '').map((f) => esc(String(r[f.n]).slice(0, 70))).slice(0, 3).join(' · ');
          return `<div class="lp-item">
            <div class="lp-item-body">
              <div class="lp-item-name">${esc(String(r[main] ?? ''))}</div>
              <div class="lp-item-meta">${secondary}</div>
            </div>
            <div class="lp-item-actions">
              <button class="lp-btn-del" data-idx="${i}">Delete</button>
            </div>
          </div>`;
        }).join('');
        listEl.querySelectorAll('button.lp-btn-del').forEach((b) => {
          b.addEventListener('click', async () => {
            const idx = +b.dataset.idx;
            const rows = data[key].slice();
            rows.splice(idx, 1);
            const r = await fetch('/api/data/' + key, {
              method: 'POST', headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(rows),
            });
            if (r.ok) { data[key] = rows; render(); toast('Deleted'); }
          });
        });
      }

      addForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        const fd = new FormData(addForm);
        const item = {};
        fields.forEach((f) => {
          let v = fd.get(f.n);
          if (v == null) v = '';
          if (f.type === 'number') v = Number(v) || 0;
          item[f.n] = v;
        });
        if (key === 'news') item.id = Date.now();
        if (key === 'products') item.id = Date.now();
        const rows = (data[key] || []).slice();
        rows.unshift(item);
        const r = await fetch('/api/data/' + key, {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(rows),
        });
        if (r.ok) { data[key] = rows; addForm.reset(); render(); toast('Added'); }
        else toast('Add failed');
      });

      render();
    });

    function esc(s) {
      return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }
  </script>
)}
