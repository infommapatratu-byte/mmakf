---
import Base from '@/layouts/Base.astro';
import Icon from '@/components/Icon.astro';
import EnrollCTA from '@/components/EnrollCTA.astro';
import { getAll } from '@/lib/storage';

export const prerender = false;

const data = await getAll();
const fed = data.federation;
const stats = data.stats;
const programs = data.programs;   // feeds the EnrollCTA program select
const events = data.events;
const news = data.news;
const achievements = data.achievements;
---

<Base title={`MMAKF — ${fed.tagline}`}>

  {/* ═══════ HERO ═══════ */}
  <section id="hero" class="hero">
    <div class="hero-photo" aria-hidden="true">
      <img src="https://images.unsplash.com/photo-1555597673-b21d5c935865?auto=format&fit=crop&w=1800&q=70" alt="" loading="eager" fetchpriority="high" />
      <div class="hero-shade"></div>
    </div>
    <div class="hero-bg" aria-hidden="true"></div>
    <div class="hero-kanji kanji" aria-hidden="true">空手道</div>
    <div class="container hero-inner">
      <div class="hero-left">
        <div class="pill featured fade">
          <span class="pill-dot"></span> Established {fed.founded} · {fed.style} · {fed.lineage}
        </div>
        <h1 class="display-1 hero-title fade">
          Forging warriors<br />
          through <em>discipline</em>,<br />
          <em>lineage</em>, and <em>purpose</em>.
        </h1>
        <p class="lead fade" style="margin-top:24px">
          {fed.name} — {fed.shortName}. Train under Grandmaster Shihan Pramod Kumar Pathak
          at our dojo in {fed.headquarters}, or join the Online University from anywhere in the world.
        </p>
        <div class="hero-actions fade" style="margin-top:36px">
          <a href="/programs" class="btn btn-primary">Explore Programs</a>
          <a href="#enroll" class="btn btn-gold">Book a Free Trial</a>
          <a href="/affiliation" class="btn btn-ghost">Affiliate a Dojo</a>
        </div>
      </div>

      <aside class="hero-right fade">
        <div class="hero-card">
          <div class="hero-card-h">Next on the Calendar</div>
          {events.slice(0, 3).map((e: any) => (
            <div class="hero-card-row">
              <div class="hero-ev-date">
                <span class="hero-ev-day">{e.day}</span>
                <span class="hero-ev-mo">{e.mo}</span>
              </div>
              <div>
                <div class="hero-card-name">{e.t}</div>
                <div class="hero-card-role">{e.type} · {e.loc}</div>
              </div>
            </div>
          ))}
          <a href="/events" class="hero-card-link">Full calendar & announcements →</a>
        </div>
      </aside>
    </div>

    <div class="hero-stats container">
      {stats.map((s: any) => (
        <div class="hero-stat">
          <div class="hero-stat-v">{s.value}</div>
          <div class="hero-stat-l">{s.label}</div>
        </div>
      ))}
    </div>
  </section>

  {/* ═══════ TICKER ═══════ */}
  <div class="ticker" aria-hidden="true">
    <div class="ticker-track">
      {Array(2).fill(0).map(() => (
        <>
          <span>Shotokan Karate</span><span class="dot">◆</span>
          <span>Kihon · Kata · Kumite</span><span class="dot">◆</span>
          <span>WKF Affiliated</span><span class="dot">◆</span>
          <span>Limca Book of Records</span><span class="dot">◆</span>
          <span>Guinness Recognized</span><span class="dot">◆</span>
          <span>Tiger Lee Lineage</span><span class="dot">◆</span>
          <span>Est. 1983</span><span class="dot">◆</span>
          <span>5,000+ Students</span><span class="dot">◆</span>
        </>
      ))}
    </div>
  </div>

  {/* ═══════ NEWS (federation homepages lead with news — MASTER-SPEC/WKF·AIFF pattern) ═══════ */}
  <section id="news">
    <div class="container">
      <div class="section-head fade" style="display:flex;align-items:flex-end;justify-content:space-between;flex-wrap:wrap;gap:16px">
        <div>
          <div class="eyebrow">Latest</div>
          <h2 class="display-2">News &amp; <em class="r">announcements</em>.</h2>
          <div class="rule"></div>
        </div>
        <a href="/events" class="btn-link" style="margin-bottom:8px">All news & results →</a>
      </div>
      <div class="grid grid-3">
        {news && news.length > 0 ? news.slice(0, 3).map((n: any) => (
          <article class="card hoverable fade">
            <div style="display:flex;gap:10px;flex-wrap:wrap;margin-bottom:14px">
              <span class="pill featured">{n.type || 'News'}</span>
              <span class="pill">{n.date}</span>
            </div>
            <div class="card-title" style="font-size:1.05rem">{n.title}</div>
            <div class="card-body">{n.body}</div>
          </article>
        )) : (
          <div style="grid-column:1/-1;text-align:center;color:var(--muted);padding:24px">
            Announcements will appear here.
          </div>
        )}
      </div>
    </div>
  </section>

  {/* ═══════ EVENTS / CALENDAR ═══════ */}
  <section id="events" class="bg-2">
    <div class="container">
      <div class="section-head fade">
        <div class="eyebrow">Calendar</div>
        <h2 class="display-2">Events &amp; <em class="r">tournaments</em>.</h2>
        <div class="rule"></div>
      </div>
      <div class="events-list fade">
        {events.slice(0, 4).map((e: any) => (
          <div class="event-row">
            <div class="event-date">
              <div class="event-day">{e.day}</div>
              <div class="event-mo">{e.mo}</div>
              {e.year && <div class="event-yr">{e.year}</div>}
            </div>
            <div class="event-body">
              <div class="event-type">{e.type}</div>
              <div class="event-title">{e.t}</div>
              <div class="event-loc"><svg width="13" height="13" viewBox="0 0 32 32" fill="none" stroke="var(--gold)" stroke-width="2" style="display:inline-block;vertical-align:-2px;margin-right:4px"><path d="M16 28s10-10 10-17a10 10 0 00-20 0c0 7 10 17 10 17z"/><circle cx="16" cy="11" r="3.5"/></svg>{e.loc}</div>
            </div>
            <div class="event-right">
              <div class="event-fee">{e.fee}</div>
              <button class="btn btn-ghost" onclick="showNotif('Registration desk opens 30 days before each event. Call +91 99391 44318.')">Register</button>
            </div>
          </div>
        ))}
      </div>
      <div class="mt-6">
        <a href="/events" class="btn btn-ghost">Full calendar →</a>
      </div>
    </div>
  </section>

  {/* ═══════ MEMBER SERVICES ═══════ */}
  <section id="member-services" style="padding:64px 0">
    <div class="container">
      <div class="ms-grid fade">
        <a href="/registration" class="ms-card">
          <div class="ms-eyebrow">Member Services</div>
          <div class="ms-title">Register with the federation</div>
          <div class="ms-desc">Athletes, instructors, dojos and officials — apply online, get your application number instantly.</div>
          <div class="ms-arrow">→</div>
        </a>
        <a href="/registration#verify" class="ms-card">
          <div class="ms-eyebrow">Bonafide Check</div>
          <div class="ms-title">Verify a member ID</div>
          <div class="ms-desc">Check any MMAKF ID against the national register — open to schools, organisers and parents.</div>
          <div class="ms-arrow">→</div>
        </a>
      </div>
    </div>
  </section>

  {/* ═══════ ABOUT / EYE OF THE WARRIOR ═══════ */}
  <section id="about">
    <div class="container">
      <div class="section-head fade">
        <div class="eyebrow">The Federation</div>
        <h2 class="display-2">The eye of the <em class="r">warrior</em>.</h2>
        <div class="rule"></div>
      </div>
      <div class="two-col">
        <p class="lead fade">
          Traditional martial arts schools teach techniques. MMAKF teaches a lineage.
          Since 1983, the federation has carried the Tiger Lee inheritance of Shotokan Karate
          through three generations of senseis and tens of thousands of students.
        </p>
        <div class="body-txt fade" style="display:flex;flex-direction:column;gap:18px">
          <p>
            We are not one dojo. We are an institutional federation — running structured programs
            across 130+ schools at our peak, with 34 active black belts, a women's empowerment
            division, an online university, and a formal pathway to the World Karate Federation.
          </p>
          <p>
            The MMAKF system develops the whole martial artist: technique, character, body, breath,
            and bearing. Train with us once, and you will understand the difference between learning
            karate and inheriting it.
          </p>
        </div>
      </div>
    </div>
  </section>

  {/* ═══════ EXPLORE THE FEDERATION ═══════ */}
  <section id="explore" class="bg-2" style="padding:64px 0">
    <div class="container">
      <div class="explore-grid fade">
        {[
          { href: '/programs',    n: '01', t: 'Training Programs',      d: 'Nine pathways — dojo and online, ages 5 to 50+.' },
          { href: '/academy',     n: '02', t: 'Online Academy',         d: 'Structured courses from white belt to Dan — learn anywhere.' },
          { href: '/facilities',  n: '03', t: 'Dojo Facilities',        d: 'Inside the hombu — training hall to first-aid.' },
          { href: '/gallery',     n: '04', t: 'Gallery',                d: 'Life on the mat — dojo, podiums and gradings.' },
          { href: '/shop',        n: '05', t: 'Federation Shop',        d: 'Certified gis, belts, equipment and merchandise.' },
          { href: '/faq',         n: '06', t: 'FAQ',                    d: 'Ages, fees, gradings and online training — answered.' },
        ].map((x) => (
          <a href={x.href} class="explore-item">
            <div class="explore-n">{x.n}</div>
            <div>
              <div class="explore-t">{x.t}</div>
              <div class="explore-d">{x.d}</div>
            </div>
            <div class="explore-arrow">→</div>
          </a>
        ))}
      </div>
    </div>
  </section>

  {/* ═══════ LINEAGE ═══════ */}
  <section id="lineage" class="bg-2">
    <div class="container">
      <div class="section-head center fade">
        <div class="eyebrow center">Heritage</div>
        <h2 class="display-2">Our <em>lineage</em> &amp; legacy.</h2>
        <div class="rule gold center"></div>
        <p class="lead" style="margin:0 auto">
          Three generations. One unbroken transmission.
        </p>
      </div>
      <div class="lineage-grid">
        <div class="lineage-step fade">
          <div class="lineage-num">01</div>
          <div class="lineage-h">Jr. Tiger Lee</div>
          <div class="lineage-sub">Source Lineage</div>
          <div class="body-txt mt-4">
            The original Shotokan authority from whom the MMAKF transmission descends.
          </div>
        </div>
        <div class="lineage-step fade">
          <div class="lineage-num">02</div>
          <div class="lineage-h">Shihan Pramod Kumar Pathak</div>
          <div class="lineage-sub">VI Dan · Grandmaster · Soke</div>
          <div class="body-txt mt-4">
            Founder of MMAKF (1983). Direct inheritor of the Tiger Lee lineage in India.
            The federation's senior technical authority.
          </div>
        </div>
        <div class="lineage-step fade">
          <div class="lineage-num">03</div>
          <div class="lineage-h">Active Senseis</div>
          <div class="lineage-sub">III–IV Dan · Federation Faculty</div>
          <div class="body-txt mt-4">
            Sensei Vikas, Sensei Dhiraj, and Sensei Sumitra — the active generation
            transmitting the system to today's students.
          </div>
        </div>
      </div>
    </div>
  </section>


  {/* ═══════ WOMEN'S DIVISION ═══════ */}
  <section id="women">
    <div class="container">
      <div class="women-grid">
        <div class="fade">
          <div class="eyebrow">Empowerment</div>
          <h2 class="display-2" style="margin-top:14px">Women's <em class="r">empowerment</em> division.</h2>
          <div class="rule"></div>
          <p class="lead">
            Led by Sensei Sumitra Devi (III Dan), MMAKF's Women's Wing is one of the longest-running
            women's martial arts programs in eastern India. Safety. Confidence. Physical authority.
          </p>
          <ul class="virtual-list mt-6">
            <li>Practical self-defense for real-world situations</li>
            <li>Confidence building and assertiveness training</li>
            <li>Free 12-week curriculum delivered through partner schools</li>
            <li>Currently running in 14 schools across Jharkhand</li>
          </ul>
          <a href="#enroll" class="btn btn-primary mt-8">Join the program</a>
        </div>
        <div class="fade women-stats">
          <div class="women-stat"><div class="women-stat-v">14</div><div class="women-stat-l">Partner schools</div></div>
          <div class="women-stat"><div class="women-stat-v">1,200+</div><div class="women-stat-l">Women trained</div></div>
          <div class="women-stat"><div class="women-stat-v">12 wk</div><div class="women-stat-l">Curriculum length</div></div>
          <div class="women-stat"><div class="women-stat-v">Free</div><div class="women-stat-l">For schools</div></div>
        </div>
      </div>
    </div>
  </section>

  {/* ═══════ ACHIEVEMENTS ═══════ */}
  <section id="achievements" class="bg-2">
    <div class="container">
      <div class="section-head fade">
        <div class="eyebrow">Recognition</div>
        <h2 class="display-2">Institutional <em>achievements</em>.</h2>
        <div class="rule gold"></div>
      </div>
      <div class="grid grid-3">
        {achievements.map((a: any) => (
          <div class="card fade">
            <div class="card-icon"><Icon name={a.icon || 'medal'} size={36} color="var(--gold)" /></div>
            <div class="card-title">{a.title}</div>
            <div class="card-body">{a.body}</div>
            <div style="margin-top:18px"><span class="pill featured">{a.badge}</span></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* ═══════ CTA / ENROLL ═══════ */}
  <EnrollCTA programs={programs} phone={fed.contact.phone} />

  {/* ═══════ CONTACT ═══════ */}
  <section id="contact">
    <div class="container">
      <div class="section-head fade">
        <div class="eyebrow">Visit</div>
        <h2 class="display-2">Visit or <em class="r">connect</em>.</h2>
        <div class="rule"></div>
      </div>
      <div class="contact-grid">
        <div class="card fade">
          <div class="card-eyebrow">Address</div>
          <div class="card-title" style="font-size:1.05rem">MMAKF Headquarters</div>
          <div class="card-body">{fed.contact.address}</div>
        </div>
        <div class="card fade">
          <div class="card-eyebrow">Email — Federation</div>
          <div class="card-title" style="font-size:1.05rem">
            <a href={`mailto:${fed.contact.email}`} class="text-gold">{fed.contact.email}</a>
          </div>
          <div class="card-body">For enrolment, federation queries, school programs.</div>
        </div>
        <div class="card fade">
          <div class="card-eyebrow">Email — Grandmaster</div>
          <div class="card-title" style="font-size:1.05rem">
            <a href="mailto:karate.pramod@gmail.com" class="text-gold">karate.pramod@gmail.com</a>
          </div>
          <div class="card-body">Shihan Pramod Kumar Pathak — direct correspondence.</div>
        </div>
        <div class="card fade">
          <div class="card-eyebrow">Phone</div>
          <div class="card-title" style="font-size:1.05rem">
            <a href={`tel:+919939144318`} class="text-gold">{fed.contact.phone}</a>
          </div>
          <div class="card-body">{fed.contact.hours}</div>
        </div>
        <div class="card fade">
          <div class="card-eyebrow">UPI / Payments</div>
          <div class="card-title" style="font-size:1.05rem">
            <span class="text-gold">{fed.upi}</span>
          </div>
          <div class="card-body">Fees, grading, equipment orders. Any UPI app.</div>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  /* ═══════ HERO ═══════ */
  .hero {
    position: relative;
    padding: 120px 0 0;
    overflow: hidden;
    border-top: 0;
  }
  .hero-photo {
    position: absolute; inset: 0;
    z-index: 0;
  }
  .hero-photo img {
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: 70% 40%;
    filter: grayscale(0.35) contrast(1.05) brightness(0.62);
  }
  .hero-shade {
    position: absolute; inset: 0;
    background:
      linear-gradient(90deg, rgba(6, 6, 7, 0.96) 0%, rgba(6, 6, 7, 0.86) 42%, rgba(6, 6, 7, 0.5) 75%, rgba(6, 6, 7, 0.65) 100%),
      linear-gradient(180deg, rgba(6, 6, 7, 0.6) 0%, transparent 30%, rgba(6, 6, 7, 0.97) 96%);
  }
  .hero-bg {
    position: absolute; inset: 0;
    z-index: 1;
    background:
      radial-gradient(ellipse 800px 400px at 80% 20%, rgba(142, 18, 18, 0.12), transparent),
      radial-gradient(ellipse 600px 600px at 10% 80%, rgba(194, 162, 75, 0.05), transparent);
    pointer-events: none;
  }
  .hero-kanji {
    position: absolute;
    top: 40px; right: -20px;
    writing-mode: vertical-rl;
    font-size: clamp(8rem, 18vw, 15rem);
    line-height: 1;
    color: rgba(237, 234, 227, 0.04);
    pointer-events: none;
    user-select: none;
    z-index: 1;
  }
  .hero-inner {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 56px;
    align-items: start;
    position: relative;
    z-index: 1;
  }
  @media (max-width: 900px) {
    .hero-inner { grid-template-columns: 1fr; gap: 36px; }
  }
  .hero-title { margin-top: 24px; }
  .hero-actions { display: flex; flex-wrap: wrap; gap: 12px; }

  .hero-right { position: sticky; top: 96px; }
  .hero-card {
    background: var(--card);
    border: 1px solid var(--border-2);
    border-radius: var(--radius);
    padding: 24px;
  }
  .hero-card-h {
    font-family: var(--font-display);
    font-size: 0.66rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gold);
    padding-bottom: 14px;
    border-bottom: 1px solid var(--border-2);
    margin-bottom: 14px;
  }
  .hero-card-row {
    display: flex;
    gap: 12px;
    padding: 10px 0;
  }
  .hero-card-row + .hero-card-row { border-top: 1px solid var(--border); }
  .hero-ev-date {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
    min-width: 34px;
    margin-top: 2px;
  }
  .hero-ev-day {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--red-2);
    line-height: 1;
  }
  .hero-ev-mo {
    font-family: var(--font-display);
    font-size: 0.56rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
    margin-top: 3px;
  }
  .hero-card-name {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.92rem;
    letter-spacing: 0.02em;
    color: var(--white);
  }
  .hero-card-role {
    font-family: var(--font-display);
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--off-white);
    margin-top: 3px;
  }
  .hero-card-link {
    display: block;
    margin-top: 14px;
    padding-top: 14px;
    border-top: 1px solid var(--border-2);
    font-family: var(--font-display);
    font-size: 0.66rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gold-2);
  }
  .hero-card-link:hover { color: var(--gold-3); }

  .hero-stats {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    margin-top: 80px;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    position: relative;
    z-index: 2;
    background: rgba(6, 6, 7, 0.55);
    backdrop-filter: blur(4px);
  }
  @media (max-width: 700px) {
    .hero-stats { grid-template-columns: repeat(2, 1fr); }
    .hero-stats > div:last-child { grid-column: 1 / -1; }
  }
  .hero-stat {
    padding: 28px 12px;
    text-align: center;
    border-left: 1px solid var(--border);
  }
  .hero-stat:first-child { border-left: 0; }
  .hero-stat-v {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 600;
    color: var(--gold);
    line-height: 1;
  }
  .hero-stat-l {
    font-family: var(--font-display);
    font-size: 0.62rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--off-white);
    margin-top: 8px;
  }

  /* ═══════ TICKER ═══════ */
  .ticker {
    background: var(--bg-2);
    border-bottom: 1px solid var(--border);
    overflow: hidden;
    padding: 16px 0;
  }
  .ticker-track {
    display: flex;
    gap: 32px;
    white-space: nowrap;
    animation: ticker 60s linear infinite;
    font-family: var(--font-display);
    font-size: 0.64rem;
    font-weight: 400;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .ticker-track .dot { color: var(--gold-dim); font-size: 0.5rem; }
  @keyframes ticker {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .ticker-track { animation: none; }
  }

  /* ═══════ EXPLORE ═══════ */
  .explore-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
  }
  @media (max-width: 900px) { .explore-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) { .explore-grid { grid-template-columns: 1fr; } }
  .explore-item {
    display: flex;
    gap: 16px;
    align-items: flex-start;
    background: var(--bg-2);
    padding: 26px 24px;
    transition: background 0.25s;
    position: relative;
  }
  .explore-item:hover { background: var(--card); }
  .explore-n {
    font-family: var(--font-display);
    font-size: 0.7rem;
    color: var(--muted);
    margin-top: 3px;
  }
  .explore-t {
    font-family: var(--font-display);
    font-size: 0.92rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--white);
  }
  .explore-d { font-size: 0.8rem; color: var(--muted); margin-top: 5px; line-height: 1.55; }
