<script>
  // Shop order intents — data attributes instead of inline handlers (MASTER-SPEC §9.6)
  document.querySelectorAll('[data-order-name]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const el = btn as HTMLElement;
      (window as any).showNotif(
        `Order ${el.dataset.orderName}: pay via UPI ${el.dataset.orderUpi}, then message us with the screenshot.`
      );
    });
  });
</script>
