---
import Base from '@/layouts/Base.astro';
import PageHero from '@/components/PageHero.astro';
import EnrollCTA from '@/components/EnrollCTA.astro';
import { get } from '@/lib/storage';

export const prerender = false;

const fed = await get('federation');
const programs = await get<any[]>('programs');

const mapQuery = encodeURIComponent(fed.contact.address || 'Patratu, Ramgarh, Jharkhand');
---

<Base
  title="Contact — MMAKF"
  description="Visit or contact MMAKF headquarters at Patratu, Jharkhand — address, phone, email, office hours and directions."
>
  <PageHero
    eyebrow="Visit"
    title={`Find the <em>dojo</em>.`}
    lead={`${fed.contact.address}. ${fed.contact.hours}.`}
    pills={['Walk-ins welcome', 'First class free']}
  />

  {/* ═══════ CONTACT CARDS + MAP ═══════ */}
  <section>
    <div class="container">
      <div class="contact-layout">
        <div class="contact-cards">
          <div class="card fade">
            <div class="card-eyebrow">Address</div>
            <div class="card-title" style="font-size:1.02rem">{fed.shortName} Headquarters</div>
            <div class="card-body">{fed.contact.address}</div>
          </div>
          <div class="card fade">
            <div class="card-eyebrow">Phone / WhatsApp</div>
            <div class="card-title" style="font-size:1.02rem">
              <a href="tel:+919939144318" class="text-gold">{fed.contact.phone}</a>
            </div>
            <div class="card-body">{fed.contact.hours}</div>
          </div>
          <div class="card fade">
            <div class="card-eyebrow">Email — Federation</div>
            <div class="card-title" style="font-size:1.02rem">
              <a href={`mailto:${fed.contact.email}`} class="text-gold">{fed.contact.email}</a>
            </div>
            <div class="card-body">Enrolment, affiliation, school programs and federation queries.</div>
          </div>
          <div class="card fade">
            <div class="card-eyebrow">Email — Grandmaster</div>
            <div class="card-title" style="font-size:1.02rem">
              <a href={`mailto:${fed.contact.emailSecondary}`} class="text-gold">{fed.contact.emailSecondary}</a>
            </div>
            <div class="card-body">Shihan Pramod Kumar Pathak — direct correspondence.</div>
          </div>
          <div class="card fade">
            <div class="card-eyebrow">UPI / Payments</div>
            <div class="card-title" style="font-size:1.02rem"><span class="text-gold">{fed.upi}</span></div>
            <div class="card-body">Fees, grading and equipment orders — any UPI app.</div>
          </div>
        </div>

        <div class="map-panel fade">
          <iframe
            title="MMAKF Headquarters — map"
            src={`https://www.google.com/maps?q=${mapQuery}&output=embed`}
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            allowfullscreen
          ></iframe>
        </div>
      </div>
    </div>
  </section>

  <EnrollCTA programs={programs} phone={fed.contact.phone} />
</Base>

<style>
  .contact-layout {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 28px;
    align-items: start;
  }
  @media (max-width: 900px) { .contact-layout { grid-template-columns: 1fr; } }
  .contact-cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: 14px;
  }
  .map-panel {
    position: sticky;
    top: 96px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--card);
    min-height: 420px;
  }
  @media (max-width: 900px) { .map-panel { position: static; min-height: 320px; } }
  .map-panel iframe {
    width: 100%;
    height: 100%;
    min-height: 420px;
    border: 0;
    display: block;
    filter: grayscale(1) invert(0.92) contrast(0.9);
  }
  @media (max-width: 900px) { .map-panel iframe { min-height: 320px; } }
</style>
