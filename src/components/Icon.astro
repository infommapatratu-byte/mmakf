---
// Inline SVG icon set for MMAKF.
// Stroke-based, gold by default, sized via the size prop.
// Replaces emoji throughout the site so it reads professional.

interface Props {
  name: string;
  size?: number;
  color?: string;
  class?: string;
}
const { name, size = 28, color = 'currentColor', class: className = '' } = Astro.props;
